{
  "name": "playbook-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/vite-safe.cjs dev",
    "dev:ui": "node ./scripts/vite-safe.cjs dev",
    "dev:api": "node --env-file=.env ./server/index.js",
    "build": "node ./scripts/vite-safe.cjs build",
    "build:widget": "node ./scripts/vite-safe.cjs build --config vite.widget.config.js",
    "preview": "node ./scripts/vite-safe.cjs preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^28.1.0",
    "vite": "^4.5.14",
    "vitest": "^4.1.2"
  }
}
